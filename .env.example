# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://api.mainnet-beta.solana.com

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Default model (optional) — overrides the built-in default
# See https://openrouter.ai/docs for available models
LLM_MODEL=xiaomi/mimo-v2-omni

# Option B: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── OKX OnchainOS Risk Data (optional) ─────────────────────────────────────────
# Enables hybrid OKX risk signals for screening. Get keys at:
# https://www.okx.com/web3/build/docs/api-guide/getting-started
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_PROJECT_ID=your_okx_project_id_here

# ── Hive Mind — Collective Intelligence (optional) ───────────────────────────
# Syncs anonymized lessons/performance with other agents for consensus wisdom.
# Set both to enable. See docs/features.md for setup instructions.
HIVE_MIND_URL=https://your-hive-server.com
HIVE_MIND_API_KEY=your_hive_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
