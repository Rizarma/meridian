# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Database Backend ──────────────────────────────────────────────────────────
# Choose your database backend: sqlite (default) or postgres
#
# For SQLite (default):
# DATABASE_BACKEND=sqlite
# DATABASE_URL=./meridian.db
#
# For Postgres (Neon, Supabase, etc.):
# DATABASE_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@pooler.neon.tech/dbname?sslmode=require
#
# When using Postgres, ensure you run the migration first:
#   pnpm db:export ./meridian.db ./backup.json
#   pnpm db:import ./backup.json $DATABASE_URL
DATABASE_BACKEND=sqlite
DATABASE_URL=./meridian.db

# ── Solana RPC ─────────────────────────────────────────────────────────────────
# Optional: override the RPC URL from user-config.json for this environment only
# RPC_URL=https://api.mainnet-beta.solana.com

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Option B: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=local-model

# Optional: override ALL LLM models with a single env var (screening, management, general)
# This takes precedence over role-specific models (managementModel, screeningModel, generalModel)
# set in user-config.json. Use those for per-role tuning; use this env var for global override.
# LLM_MODEL=anthropic/claude-3.5-sonnet

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here
JUPITER_API_KEY=your_jupiter_api_key_here

# ── OKX OnchainOS Risk Data (optional) ─────────────────────────────────────────
# Enables hybrid OKX risk signals for screening. Get keys at:
# https://www.okx.com/web3/build/docs/api-guide/getting-started
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_PROJECT_ID=your_okx_project_id_here

# Alternative OKX credential names (fallback aliases)
# If you already have OKX credentials with different env var names, these work too:
# OK_ACCESS_KEY=your_okx_api_key_here
# OK_ACCESS_SECRET=your_okx_secret_key_here
# OK_ACCESS_PASSPHRASE=your_okx_passphrase_here
# OK_ACCESS_PROJECT=your_okx_project_id_here

# ── Hive Mind — Collective Intelligence (optional) ───────────────────────────
# Syncs anonymized lessons/performance with other agents for consensus wisdom.
# Set all three to enable. See docs/features.md for setup instructions.
HIVE_MIND_URL=https://your-hive-server.com
HIVE_MIND_API_KEY=your_hive_api_key_here
HIVE_MIND_AGENT_ID=your_agent_id_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Path Configuration ─────────────────────────────────────────────────────────
# Optional: override project root directory for data files (lessons.json, pool-memory.json, etc.)
# If not set, auto-detected by looking for package.json
# MERIDIAN_ROOT=./

# Optional: override database file path (default: meridian.db in project root)
# MERIDIAN_DB=/path/to/custom/meridian.db

# Optional: enable dual-write to pool-memory.json backup (default: false)
# Set to "true" to write pool data to both SQLite and JSON file during migration
# POOL_MEMORY_DUAL_WRITE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
# Optional: override dry-run mode for this environment only
# DRY_RUN=false
LOG_LEVEL=info

# Optional: enable verbose SQL read debugging to diagnose empty result issues.
# When set to "true", logs every SELECT/read query with SQL, params, row count,
# a preview of returned data, and query duration in ms.
# SQL_DEBUG_READS=true

# Optional: set timezone for log timestamps (default: UTC)
# Accepts IANA timezone names like "Asia/Jakarta", "America/New_York", "Asia/Tokyo"
# Invalid timezones fall back to UTC with a warning. File rotation still uses UTC dates.
# TZ=Asia/Jakarta
