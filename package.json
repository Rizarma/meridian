{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "dist/src/index.js",
  "bin": {
    "meridian": "dist/src/cli/cli.js"
  },
  "scripts": {
    "setup": "pnpm run build && node dist/src/cli/setup.js",
    "build": "tsc && node build.js",
    "start": "pnpm run build && node dist/src/index.js",
    "dev": "pnpm run build && cross-env DRY_RUN=true node dist/src/index.js",
    "test:phase0:exit": "pnpm run build && node dist/test/phase-0-exit-rules.test.js",
    "test:phase0:trailing": "pnpm run build && node dist/test/phase-0-trailing-tp.test.js",
    "test:phase0:config": "pnpm run build && node dist/test/phase-0-config-mutation.test.js",
    "test:phase0:safety": "pnpm run build && node dist/test/phase-0-tool-safety.test.js",
    "test:phase0:all": "pnpm run build && node dist/test/phase-0-exit-rules.test.js && node dist/test/phase-0-trailing-tp.test.js && node dist/test/phase-0-config-mutation.test.js && node dist/test/phase-0-tool-safety.test.js",
    "test:screen": "pnpm run build && node dist/test/test-screening.js",
    "test:agent": "pnpm run build && cross-env DRY_RUN=true node dist/test/test-agent.js",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=json pnpm test:phase0:all",
    "test:coverage:check": "c8 --reporter=text --check-coverage pnpm test:phase0:all",
    "unused-deps": "depcheck --ignores='@types/*,cross-env,husky,lint-staged,c8,depcheck'",
    "prepare": "pnpm run build",
    "prepack": "pnpm run build",
    "postinstall": "node scripts/patch-anchor.js",
    "typecheck": "tsc --noEmit",
    "format:changed": "node dist/scripts/biome-changed.js",
    "format:check": "node dist/scripts/biome-changed.js check",
    "format:all": "biome format --write .",
    "lint:changed": "node dist/scripts/biome-lint-changed.js",
    "lint:check": "node dist/scripts/biome-lint-changed.js check",
    "check": "pnpm format:check && pnpm typecheck"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/spl-token": "^0.3.11",
    "@solana/web3.js": "^1.95.0",
    "async-mutex": "^0.5.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.3.1",
    "grammy": "^1.42.0",
    "jsonrepair": "^3.13.3",
    "log-update": "^6.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**",
    "scripts/patch-anchor.js",
    "README.md",
    ".env.example",
    "user-config.example.json"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "c8": "^10.1.2",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "."
  ]
}
