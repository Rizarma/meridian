{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "build": "tsc && node build.js",
    "start": "npm run build && node dist/index.js",
    "dev": "npm run build && cross-env DRY_RUN=true node dist/index.js",
    "test:screen": "npm run build && node dist/test/test-screening.js",
    "test:agent": "npm run build && cross-env DRY_RUN=true node dist/test/test-agent.js",
    "postinstall": "node scripts/patch-anchor.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/spl-token": "^0.3.11",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
